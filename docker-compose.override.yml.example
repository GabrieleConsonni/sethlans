# OPTIONAL override for those who build behind a private/proxy npm registry.
#
# `docker compose up` automatically loads docker-compose.yml + docker-compose.override.yml
# (if present). Copy this file to `docker-compose.override.yml` (gitignored) to
# inject your ~/.npmrc as a BuildKit secret during the frontend build.
#
#   cp docker-compose.override.yml.example docker-compose.override.yml
#
# The token does NOT end up in the image (it is a build secret). The Dockerfile declares the
# secret as optional (required=false): without this override the build uses the public registry.

services:
  frontend:
    build:
      secrets:
        - npmrc

secrets:
  npmrc:
    file: ${NPMRC_FILE:-${USERPROFILE}/.npmrc}   # your ~/.npmrc with registry + token
