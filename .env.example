# Tabula local configuration — copy to `.env` and adapt to your values.
# The `.env` file is gitignored: do NOT commit it (it may contain internal hosts/credentials).
# docker-compose automatically loads it for variable substitution.

# Backend Postgres connection (schema `tabula`).
# For Docker, use the host reachable from the containers (e.g. host.docker.internal).
TABULA_DB_URL=postgresql+psycopg2://postgres:password@host.docker.internal:5432/tabula

# (Optional) path to a ~/.npmrc for a private/proxy npm registry, used by the
# frontend in dev mode. Leave empty to use the public registry.
# Windows example: NPMRC_FILE=C:/Users/<user>/.npmrc
NPMRC_FILE=
