# Configurazione locale di Tabula — copia in `.env` e adatta ai tuoi valori.
# Il file `.env` è gitignorato: NON committarlo (può contenere host/credenziali interni).
# docker-compose lo carica automaticamente per la sostituzione delle variabili.

# Connessione Postgres del backend (schema `tabula`).
# Per Docker usa l'host raggiungibile dai container (es. host.docker.internal).
TABULA_DB_URL=postgresql+psycopg2://postgres:password@host.docker.internal:5432/tabula

# (Opzionale) percorso a un ~/.npmrc per un registry npm privato/proxy, usato dal
# frontend in modalità dev. Lascia vuoto per usare il registry pubblico.
# Esempio Windows: NPMRC_FILE=C:/Users/<utente>/.npmrc
NPMRC_FILE=
